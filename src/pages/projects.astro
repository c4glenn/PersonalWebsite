---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TagFilter from '../components/TagFilter.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const sorted = allProjects.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.startDate.getTime() - a.data.startDate.getTime();
});

const allTags = [...new Set(sorted.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Projects — Philip Smith" description="Software projects, internships, and things I've built.">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">Projects</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-10">
      Things I've built, companies I've worked with, and experiments I've shipped.
    </p>

    <TagFilter tags={allTags} />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {sorted.map(project => <ProjectCard project={project} />)}
    </div>
  </div>
</BaseLayout>
