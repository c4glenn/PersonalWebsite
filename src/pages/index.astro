---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Philip Smith" description="Personal website of Philip Smith — Robotics Engineering MS student at WPI researching multi-robot systems and swarm robotics.">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="max-w-2xl">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">
        Hi, I'm Philip.
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
        Master's student in Robotics Engineering at Worcester Polytechnic Institute. I research
        multi-robot coordination, task allocation, and human–swarm interaction — working toward
        scalable and reliable swarm robotics.
      </p>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
        My background spans coordination algorithms, ROS2/Gazebo simulation, machine vision,
        and embedded systems. I've presented at ROSCon and multiple research symposia, and
        interned across robotics startups and academic labs.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/projects"
          class="px-5 py-2.5 rounded-lg bg-accent dark:bg-accent-light text-white dark:text-gray-950 font-medium text-sm hover:opacity-90 transition-opacity"
        >
          View Projects
        </a>
        <a
          href="/research"
          class="px-5 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:border-accent dark:hover:border-accent-light hover:text-accent dark:hover:text-accent-light transition-colors"
        >
          Research
        </a>
        <a
          href="/blog"
          class="px-5 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:border-accent dark:hover:border-accent-light hover:text-accent dark:hover:text-accent-light transition-colors"
        >
          Blog
        </a>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  {featured.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Featured Work</h2>
        <a href="/projects" class="text-sm text-accent dark:text-accent-light hover:underline">
          All projects →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.map(project => <ProjectCard project={project} />)}
      </div>
    </section>
  )}
</BaseLayout>
