---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { formatDateRange, formatFullDate } from '../../utils/dates';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, startDate, endDate, tags, repoUrl, liveUrl, company, role, featured, relatedProjects, relatedResearch } = project.data;

const relatedProjectEntries = (
  await Promise.all(relatedProjects.map(id => getEntry('projects', id)))
).filter(Boolean);

const relatedResearchEntries = (
  await Promise.all(relatedResearch.map(id => getEntry('research', id)))
).filter(Boolean);
---

<BaseLayout title={`${title} — Philip Smith`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-16">

    <!-- Back link -->
    <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-500 hover:text-accent dark:hover:text-accent-light transition-colors mb-10">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      All projects
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-violet-100 dark:bg-violet-900/40 text-accent dark:text-accent-light font-medium">
            {tag}
          </span>
        ))}
        {featured && (
          <span class="text-xs px-2.5 py-1 rounded-full bg-accent/10 dark:bg-accent-light/10 text-accent dark:text-accent-light font-medium">
            Featured
          </span>
        )}
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-3">
        {title}
      </h1>

      {role && company && (
        <p class="text-accent dark:text-accent-light font-medium mb-1">{role} · {company}</p>
      )}

      <time class="text-sm text-gray-500 dark:text-gray-500">
        {formatDateRange(startDate, endDate)}
      </time>

      <!-- External links -->
      {(repoUrl || liveUrl) && (
        <div class="flex items-center gap-4 mt-4">
          {repoUrl && (
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              GitHub
            </a>
          )}
          {liveUrl && (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Live site
            </a>
          )}
        </div>
      )}
    </header>

    <!-- Body -->
    <div class="prose prose-gray dark:prose-invert max-w-none prose-a:text-accent dark:prose-a:text-accent-light prose-headings:font-semibold">
      <Content />
    </div>

    <!-- Related items -->
    {(relatedResearchEntries.length > 0 || relatedProjectEntries.length > 0) && (
      <aside class="mt-16 pt-10 border-t border-gray-200 dark:border-gray-800">
        {relatedResearchEntries.length > 0 && (
          <div class="mb-8">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-500 mb-4">
              Related Research
            </h2>
            <ul class="space-y-3">
              {relatedResearchEntries.map(entry => entry && (
                <li>
                  <a
                    href={`/research/${entry.id}`}
                    class="group flex flex-col p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-accent/50 dark:hover:border-accent-light/50 transition-colors"
                  >
                    <span class="font-medium text-gray-900 dark:text-white group-hover:text-accent dark:group-hover:text-accent-light transition-colors text-sm">
                      {entry.data.title}
                    </span>
                    {entry.data.venue && (
                      <span class="text-xs text-gray-500 dark:text-gray-500 mt-0.5">{entry.data.venue}</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {relatedProjectEntries.length > 0 && (
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-500 mb-4">
              Related Projects
            </h2>
            <ul class="space-y-3">
              {relatedProjectEntries.map(entry => entry && (
                <li>
                  <a
                    href={`/projects/${entry.id}`}
                    class="group flex flex-col p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-accent/50 dark:hover:border-accent-light/50 transition-colors"
                  >
                    <span class="font-medium text-gray-900 dark:text-white group-hover:text-accent dark:group-hover:text-accent-light transition-colors text-sm">
                      {entry.data.title}
                    </span>
                    <span class="text-xs text-gray-500 dark:text-gray-500 mt-0.5">
                      {formatDateRange(entry.data.startDate, entry.data.endDate)}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    )}
  </article>
</BaseLayout>
