---
import type { CollectionEntry } from 'astro:content';
import { formatFullDate } from '../utils/dates';

interface Props {
  entry: CollectionEntry<'research'>;
}

const { entry } = Astro.props;
const { title, description, date, tags, paperFile, arxivUrl, doiUrl, venue, authors } = entry.data;
---

<article class="flex flex-col p-6 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-gray-300 dark:hover:border-gray-700 hover:shadow-md dark:hover:shadow-gray-900 transition-all duration-200">
  <div class="mb-3">
    <h3 class="font-semibold text-gray-900 dark:text-white mb-1">
      <a href={`/research/${entry.id}`} class="hover:text-accent dark:hover:text-accent-light transition-colors">
        {title}
      </a>
    </h3>
    {venue && (
      <p class="text-sm font-medium text-accent dark:text-accent-light">{venue}</p>
    )}
    {authors.length > 0 && (
      <p class="text-sm text-gray-500 dark:text-gray-500 mt-0.5">{authors.join(', ')}</p>
    )}
  </div>

  <time class="text-xs text-gray-500 dark:text-gray-500 mb-3" datetime={date.toISOString()}>
    {formatFullDate(date)}
  </time>

  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1 mb-4">
    {description}
  </p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {tags.map(tag => (
      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
        {tag}
      </span>
    ))}
  </div>

  <div class="flex items-center gap-3 flex-wrap mt-auto">
    {paperFile && (
      <a
        href={`/papers/${paperFile}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        PDF
      </a>
    )}
    {arxivUrl && (
      <a
        href={arxivUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors"
      >
        arXiv
      </a>
    )}
    {doiUrl && (
      <a
        href={doiUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-xs font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors"
      >
        DOI
      </a>
    )}
    <a
      href={`/research/${entry.id}`}
      class="text-xs font-medium text-gray-600 dark:text-gray-400 hover:text-accent dark:hover:text-accent-light transition-colors ml-auto"
    >
      Read more →
    </a>
  </div>
</article>
