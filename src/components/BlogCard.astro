---
import type { CollectionEntry } from 'astro:content';
import { formatFullDate } from '../utils/dates';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;
---

<article class="group flex flex-col sm:flex-row gap-4 py-6 border-b border-gray-200 dark:border-gray-800 last:border-0">
  <time class="shrink-0 text-sm text-gray-500 dark:text-gray-500 sm:w-32 pt-0.5" datetime={date.toISOString()}>
    {formatFullDate(date)}
  </time>

  <div class="flex-1">
    <h3 class="font-semibold text-gray-900 dark:text-white mb-1">
      <a
        href={`/blog/${post.id}`}
        class="hover:text-accent dark:hover:text-accent-light transition-colors"
      >
        {title}
      </a>
    </h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
          {tag}
        </span>
      ))}
    </div>
  </div>
</article>
