---
import type { CollectionEntry } from 'astro:content';
import { formatDateRange } from '../utils/dates';

interface Props {
  entry: CollectionEntry<'experience'>;
}

const { entry } = Astro.props;
const { title, company, location, type, description, startDate, endDate, tags } = entry.data;

const typeLabel: Record<string, string> = {
  internship: 'Internship',
  research: 'Research',
  teaching: 'Teaching',
  other: '',
};
---

<div class="group relative flex gap-6">
  <!-- Timeline spine -->
  <div class="flex flex-col items-center">
    <div class="mt-1.5 w-2.5 h-2.5 rounded-full bg-accent dark:bg-accent-light shrink-0 ring-4 ring-white dark:ring-gray-950"></div>
    <div class="mt-1 w-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
  </div>

  <!-- Content -->
  <div class="pb-10 flex-1 min-w-0">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 mb-1">
      <div>
        <a
          href={`/experience/${entry.id}`}
          class="font-semibold text-gray-900 dark:text-white hover:text-accent dark:hover:text-accent-light transition-colors"
        >
          {title}
        </a>
        <span class="text-gray-500 dark:text-gray-500"> · </span>
        <span class="text-gray-700 dark:text-gray-300">{company}</span>
        {location && (
          <span class="text-gray-500 dark:text-gray-500">, {location}</span>
        )}
      </div>
      <time class="shrink-0 text-sm text-gray-500 dark:text-gray-500 tabular-nums">
        {formatDateRange(startDate, endDate)}
      </time>
    </div>

    {typeLabel[type] && (
      <span class="inline-block text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 mb-2">
        {typeLabel[type]}
      </span>
    )}

    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
          {tag}
        </span>
      ))}
    </div>
  </div>
</div>
